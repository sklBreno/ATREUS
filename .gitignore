# ============================================================
# ATREUS - .gitignore
# ============================================================

# ============================================================
# Python
# ============================================================

__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Compiled extensions
*.so

# ============================================================
# Virtual Environment
# ============================================================

.venv/
venv/
env/
ENV/

# ============================================================
# Build / Distribution
# ============================================================

build/
dist/
downloads/
.eggs/
*.egg-info/
*.egg

# ============================================================
# Python Tools
# ============================================================

.pytest_cache/
.coverage
.coverage.*
htmlcov/

.mypy_cache/
.ruff_cache/
.pyre/
.tox/
.nox/

# ============================================================
# IDEs
# ============================================================

.vscode/
.idea/

*.code-workspace

# ============================================================
# Environment Variables
# ============================================================

.env
.env.*
!.env.example

# ============================================================
# Logs
# ============================================================

*.log

# Ignore runtime logs generated by the application
logs/*

# Keep folder structure
!logs/.gitkeep

# ============================================================
# Local Storage
# ============================================================

storage/*

# Keep folder structure
!storage/.gitkeep

# ============================================================
# Operating System
# ============================================================

.DS_Store
Thumbs.db
Desktop.ini

# ============================================================
# Jupyter
# ============================================================

.ipynb_checkpoints/

# ============================================================
# Temporary Files
# ============================================================

*.tmp
*.bak
*.swp
*.swo
*~

# ============================================================
# Package Managers
# ============================================================

pip-wheel-metadata/

# ============================================================
# PyInstaller
# ============================================================

*.manifest
*.spec

# ============================================================
# Local Runtime Files
# ============================================================

.cache/

# ============================================================
# Project Notes (Optional)
# ============================================================

notes/
scratch/